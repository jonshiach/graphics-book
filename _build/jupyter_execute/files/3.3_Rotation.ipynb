    "t = np.mean(P[:3,:],axis=1)\n",
    "T1 = translation(-t)\n",
    "T2 = translation(t)\n",
    "A = np.linalg.multi_dot((T2, Ry, T1))\n",
    "P2 = np.dot(A, P)\n",
    "\n",
    "# Plot polygons\n",
    "fig, ax = plt.subplots()\n",
