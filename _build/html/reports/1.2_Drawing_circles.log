phi = np.arange(-np.pi / 4, 0, 0.001)
x, y = np.cos(phi), np.sin(phi)
x = np.append(x, 0)
y = np.append(y, 0)
plt.fill(x, y, fc=blue, ec="none")

theta = np.linspace(0, 2 * np.pi, 200)
